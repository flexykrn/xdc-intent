# XDC Network RPC Endpoints
XDC_TESTNET_RPC=https://erpc.apothem.network
XDC_MAINNET_RPC=https://erpc.xinfin.network

# Deployer Wallet (fresh key for mainnet — never reuse testnet keys)
DEPLOYER_PRIVATE_KEY=0x...

# Treasury Address (where protocol fees go)
# For testnet: can use deployer address
# For mainnet: use dedicated multisig or hardware wallet
TREASURY_ADDRESS=0x...

# Contract Verification
XDC_API_KEY=YOUR_XDC_API_KEY_HERE

# Gas Settings
GAS_PRICE_GWEI=25
GAS_LIMIT=5000000

# Protocol Fee (basis points, 10 = 0.1%)
PROTOCOL_FEE_BPS=10

# Solver Bond Amount (in wei, 10000 XDC = 10000000000000000000000)
SOLVER_BOND_AMOUNT=10000000000000000000000

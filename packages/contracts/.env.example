# ── Network ──
XDC_TESTNET_RPC=https://erpc.apothem.network
XDC_MAINNET_RPC=https://erpc.xinfin.network
ETHEREUM_SEPOLIA_RPC=https://rpc.sepolia.org
SEPOLIA_RPC_URL=https://rpc.sepolia.org
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ── Keys (NEVER commit) ──
DEPLOYER_PRIVATE_KEY=
SOLVER_PRIVATE_KEY=
X402_FACILITATOR_PRIVATE_KEY=

# ── Deployed Contract Addresses (populated after deployment) ──
ESCROW_ADDRESS=
INTENT_REGISTRY_ADDRESS=
PAYMENT_VERIFIER_ADDRESS=
MOCK_BRIDGE_ADDRESS=

# ── LayerZero Testnet ──
# Used by scripts/deploy-lz-testnet-stack.ts and scripts/run-lz-e2e.ts
# SEPOLIA_RPC_URL and ARBITRUM_SEPOLIA_RPC_URL must be set above.
# SOLVER_PRIVATE_KEY is also required for solver registration in the deploy script.

# ── Bridge Keeper ──
# Comma-separated list of supported mock destination chain IDs
KEEPER_DEST_CHAIN_IDS=99999,88888
KEEPER_POLL_INTERVAL_MS=5000
KEEPER_LOOKBACK_BLOCKS=1000

# ── Services ──
SOLVER_API_PORT=3001
X402_FACILITATOR_PORT=3002
DATABASE_URL=sqlite://./data/solver.db
FRONTEND_API_URL=http://localhost:3001

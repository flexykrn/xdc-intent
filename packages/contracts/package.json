{
  "name": "@xdc-intent/contracts",
  "version": "1.0.0",
  "description": "XDC Intent Framework Smart Contracts",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "clean": "rm -rf artifacts cache typechain-types",
    "lint": "solhint 'contracts/**/*.sol'",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhat",
    "deploy:apothem": "hardhat run scripts/deploy.ts --network apothem",
    "deploy:xdc": "hardhat run scripts/deploy.ts --network xdc"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "dotenv": "^16.3.1",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.5",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.0",
    "typescript": "^5.3.3"
  }
}

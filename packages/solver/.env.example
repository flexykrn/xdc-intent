# XDC Network RPC Endpoints
XDC_TESTNET_RPC=https://erpc.apothem.network
XDC_MAINNET_RPC=https://erpc.xinfin.network

# Solver Wallet (for fulfilling intents)
SOLVER_PRIVATE_KEY=0x...

# Contract Addresses (fill after deployment)
ESCROW_ADDRESS=0x...
PAYMENT_VERIFIER_ADDRESS=0x...
INTENT_REGISTRY_ADDRESS=0x...

# Middleware URL
MIDDLEWARE_URL=http://localhost:3001

# Database
DATABASE_PATH=./solver.db

# Logging
LOG_LEVEL=info

# Gas Settings
MAX_GAS_PRICE_GWEI=50
GAS_LIMIT=500000

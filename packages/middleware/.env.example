# Server Configuration
PORT=3001
NODE_ENV=development

# XDC Network RPC Endpoints
XDC_TESTNET_RPC=https://erpc.apothem.network
XDC_MAINNET_RPC=https://erpc.xinfin.network

# Contract Addresses (fill after deployment)
ESCROW_ADDRESS=0x...
PAYMENT_VERIFIER_ADDRESS=0x...
INTENT_REGISTRY_ADDRESS=0x...

# Middleware Wallet (for signing proofs)
MIDDLEWARE_PRIVATE_KEY=0x...

# Protocol Fee (basis points, 10 = 0.1%)
PROTOCOL_FEE_BPS=10

# Treasury Address (where fees go)
TREASURY_ADDRESS=0x...

# Solver Bond Amount (in wei)
SOLVER_BOND_AMOUNT=10000000000000000000000

# Rate Limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=100

# API Keys (for premium tier access)
API_KEY_FREE=free-tier-key
API_KEY_PRO=pro-tier-key
API_KEY_ENTERPRISE=enterprise-tier-key

# Database
DATABASE_PATH=./middleware.db

# Logging
LOG_LEVEL=info

# XDC Network RPC Endpoints
XDC_TESTNET_RPC=https://erpc.apothem.network
XDC_MAINNET_RPC=https://erpc.xinfin.network

# Bridge Configuration
# Wanchain Bridge (selected provider)
WANCHAIN_BRIDGE_ADDRESS=0x...
WANCHAIN_RPC=https://api.wanchain.org

# Ethereum Sepolia (for cross-chain testing)
ETHEREUM_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Contract Addresses (fill after deployment)
ESCROW_ADDRESS=0x...
PAYMENT_VERIFIER_ADDRESS=0x...
INTENT_REGISTRY_ADDRESS=0x...

# Bridge Wallet (for relay operations)
BRIDGE_PRIVATE_KEY=0x...

# Logging
LOG_LEVEL=info

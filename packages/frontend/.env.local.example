# Copy this file to .env.local and add your actual API keys.
# Never commit real API keys.
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional: The Graph / Goldsky subgraph query URL.
# When set, the Dashboard will prefer subgraph data over RPC polling.
NEXT_PUBLIC_SUBGRAPH_URL=

# Optional: custom RPC endpoints for supported testnets.
# When omitted, public RPCs are used.
NEXT_PUBLIC_APOTHEM_RPC_URL=https://erpc.apothem.network
NEXT_PUBLIC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC_URL=

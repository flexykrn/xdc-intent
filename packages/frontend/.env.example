# Vite Environment Variables
# Must start with VITE_ to be exposed to the client

# XDC Network RPC Endpoints
VITE_XDC_TESTNET_RPC=https://erpc.apothem.network
VITE_XDC_MAINNET_RPC=https://erpc.xinfin.network

# Contract Addresses (fill after deployment)
VITE_ESCROW_ADDRESS=0x...
VITE_PAYMENT_VERIFIER_ADDRESS=0x...
VITE_INTENT_REGISTRY_ADDRESS=0x...

# Middleware URL
VITE_MIDDLEWARE_URL=http://localhost:3001

# App Configuration
VITE_APP_NAME=XDC Intent Framework
VITE_APP_VERSION=1.0.0
